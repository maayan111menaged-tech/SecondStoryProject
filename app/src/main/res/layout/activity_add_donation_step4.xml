<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".screens.AddDonationStep4Activity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Step Indicator -->
        <LinearLayout
            android:id="@+id/stepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/step1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="1"
                android:textColor="#AAAAAA"
                android:background="@drawable/circle_outline"
                android:textStyle="bold"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/step2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="2"
                android:textColor="#AAAAAA"
                android:background="@drawable/circle_outline"
                android:textStyle="bold"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/step3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="3"
                android:textColor="#AAAAAA"
                android:background="@drawable/circle_outline"
                android:textStyle="bold"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/step4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="4"
                android:textColor="#FFFFFF"
                android:background="@drawable/circle_filled"
                android:textStyle="bold"
                android:layout_margin="4dp"/>
        </LinearLayout>

        <!-- Preview Image -->
        <ImageView
            android:id="@+id/imgPreview"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:layout_marginBottom="16dp"
            android:background="#AAAAAA"/>

        <!-- Donation Name -->
        <TextView
            android:id="@+id/tvPreviewName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שם התרומה"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Description -->
        <TextView
            android:id="@+id/tvPreviewDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="תיאור התרומה"
            android:layout_marginBottom="8dp"/>

        <!-- City -->
        <TextView
            android:id="@+id/tvPreviewCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="עיר"
            android:layout_marginBottom="8dp"/>

        <!-- Category -->
        <TextView
            android:id="@+id/tvPreviewCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="קטגוריה"
            android:layout_marginBottom="24dp"/>

        <!-- Confirm Button -->
        <Button
            android:id="@+id/btnConfirmDonation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="פרסם את התרומה"/>
    </LinearLayout>
</ScrollView>