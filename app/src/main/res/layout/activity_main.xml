<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".screens.MainActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- כותרות -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/littleTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/akitrg__"
                android:text="מעניקים לחפצים"
                android:textColor="@color/black"
                android:textSize="23pt"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/littleTitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="-3dp"
                android:layout_marginTop="-3dp"
                android:fontFamily="@font/akitrg__"
                android:text="מעניקים לחפצים"
                android:textColor="#36b3b8"
                android:textSize="23pt"
                android:textStyle="bold" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">
             <TextView
                 android:id="@+id/bigTitle"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:layout_gravity="center"
                 android:fontFamily="@font/noot"
                 android:text="סיפור שני"
                 android:textColor="#36b3b8"
                 android:textSize="23pt"
                 android:textStyle="bold" />

            <TextView
                android:id="@+id/bigTitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="-5dp"
                android:layout_marginTop="-5dp"
                android:fontFamily="@font/noot"
                android:text="סיפור שני"
                android:textColor="@color/black"
                android:textSize="23pt"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- כפתורים -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="25dp"
            android:layoutDirection="rtl"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_addDonation"
                android:layout_width="177dp"
                android:layout_height="wrap_content"
                android:text="הוספת תרומה"
                android:textSize="11pt"
                android:textColor="@android:color/black"
                android:fontFamily="@font/akitrg__"
                android:backgroundTint="#36b3b8"
                app:icon="@drawable/baseline_add_circle_24"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="30dp"
                app:iconTint="#144244"/>

            <!-- רווח אוטומטי -->
            <View
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_searchDonation"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:text="חיפוש תרומה"
                android:textSize="11pt"
                android:textColor="@android:color/black"
                android:fontFamily="@font/akitrg__"
                android:backgroundTint="#36b3b8"
                app:icon="@drawable/ic_search"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconSize="30dp"
                app:iconTint="#144244"/>
        </LinearLayout>

        <!-- מפה placeholder -->
        <FrameLayout
            android:id="@+id/mapContainer"
            android:layout_width="350dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true">

            <org.osmdroid.views.MapView
                android:id="@+id/miniMap"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- שכבה שקופה שתופסת את הלחיצה -->
            <View
                android:id="@+id/mapClickOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>

        <!-- דרגות -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- תצוגה רגילה (לא מקסימלית) -->
            <LinearLayout
                android:id="@+id/normalLevelLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- שמות רמות -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layoutDirection="rtl">

                    <TextView
                        android:id="@+id/currentLevelName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/akitrg__"
                        android:textSize="10pt"
                        android:textColor="@color/black"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/nextLevelName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/akitrg__"
                        android:textSize="10pt"
                        android:textColor="#888888"/>
                </LinearLayout>

                <!-- אייקונים + בר -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:layoutDirection="rtl">

                    <ImageView
                        android:id="@+id/currentRateIcon"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:contentDescription="Current Rate Icon"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp">

                        <!-- תוויות מעל הבר -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layoutDirection="rtl">

                            <TextView
                                android:id="@+id/progressText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="9pt"
                                android:textColor="#36b3b8"
                                android:fontFamily="@font/akitrg__"/>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1"/>

                            <TextView
                                android:id="@+id/remainingText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="9pt"
                                android:textColor="#888888"
                                android:fontFamily="@font/akitrg__"/>
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/rateProgressBar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="16dp"
                            android:layout_marginTop="4dp"
                            android:layoutDirection="rtl"
                            android:progress="0"
                            android:max="100"
                            android:progressDrawable="@drawable/progress_bar_style"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/nextRateIcon"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:contentDescription="Next Rate Icon"/>
                </LinearLayout>

                <!-- סה"כ תרומות -->
                <TextView
                    android:id="@+id/totalDonationsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:fontFamily="@font/akitrg__"
                    android:textSize="9pt"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- תצוגה מקסימלית -->
            <LinearLayout
                android:id="@+id/maxLevelLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/maxLevelIcon"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:contentDescription="Max Level Icon"/>

                <TextView
                    android:id="@+id/maxLevelTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/akitrg__"
                    android:textSize="13pt"
                    android:textStyle="bold"
                    android:textColor="#36b3b8"/>

                <TextView
                    android:id="@+id/maxLevelSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/akitrg__"
                    android:textSize="10pt"
                    android:textColor="#888888"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>