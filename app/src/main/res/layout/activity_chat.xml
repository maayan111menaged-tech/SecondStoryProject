<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- כותרת השיחה -->
    <TextView
        android:id="@+id/tv_chat_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:text="שיחה" />

    <!--
        ✅ באנר דינמי – משמש לשני מקרים:
        1. משתמש לא פעיל (isActive=false)  → טקסט + קלט חסום
        2. משתמש נמחק (donorDeleted=true)  → טקסט + כפתור "מחק שיחה"
        הטקסט והכפתור מוגדרים מ-ChatActivity לפי המצב
    -->
    <LinearLayout
        android:id="@+id/layout_user_status_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFEBEE"
        android:padding="12dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- שורת אייקון + טקסט -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_banner_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⛔"
                android:textSize="16sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_banner_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textColor="#C62828"
                android:textStyle="bold"
                tools:text="משתמש זה אינו פעיל." />

        </LinearLayout>

        <!-- ✅ כפתור מחק שיחה – גלוי רק כשהמשתמש נמחק -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_chat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="🗑 מחק שיחה"
            android:textColor="@android:color/white"
            android:backgroundTint="#E53935"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

    <!-- רשימת הודעות -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- שורת שליחת הודעה -->
    <LinearLayout
        android:id="@+id/layout_message_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="כתוב הודעה..."
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:padding="10dp"
            android:background="@drawable/bg_message_input"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="שלח"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp" />

    </LinearLayout>

</LinearLayout>